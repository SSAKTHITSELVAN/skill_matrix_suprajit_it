generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CTO
  DEPARTMENT_HEAD
  MANAGER
  LEAD
  EMPLOYEE
}

enum Category {
  HW
  SW
  DEVOPS
  MANAGEMENT
}

enum Platform {
  CORE
  COMMERCIAL
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SkillStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ProficiencyLevel {
  BEGINNER
  MEDIUM
  EXPERT
  MASTER
}

model User {
  id                   Int       @id @default(autoincrement())
  name                 String
  email                String    @unique
  password_hash        String
  role                 Role
  category             Category?
  platform             Platform?
  stream               String?
  department           String?
  designation          String?
  manager_id           Int?
  lead_id              Int?
  department_head_id   Int?
  updated_by_id        Int?
  date_of_joining      DateTime?
  years_of_experience  Int?
  project_name         String?
  project_role         String?
  must_change_password Boolean   @default(true)
  status               String    @default("active")
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt

  manager        User?  @relation("ManagerRelation", fields: [manager_id], references: [id])
  managerOf      User[] @relation("ManagerRelation")
  lead           User?  @relation("LeadRelation", fields: [lead_id], references: [id])
  leadOf         User[] @relation("LeadRelation")
  departmentHead User?  @relation("DeptHeadRelation", fields: [department_head_id], references: [id])
  deptHeadOf     User[] @relation("DeptHeadRelation")
  updatedBy      User?  @relation("UpdatedByRelation", fields: [updated_by_id], references: [id])
  updatedByOf    User[] @relation("UpdatedByRelation")

  skills        EmployeeSkill[]
  createdSkills Skill[]           @relation("SkillCreator")
  approvals     ApprovalRequest[] @relation("ApprovalUser")
  changedBy     ApprovalRequest[] @relation("ApprovalChanger")
  approvedBy    ApprovalRequest[] @relation("ApprovalApprover")
}

model Skill {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  created_by Int
  max_topics Int      @default(10)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  creator User            @relation("SkillCreator", fields: [created_by], references: [id])
  users   EmployeeSkill[]
  topics  SkillTopic[]
}

model SkillTopic {
  id          Int      @id @default(autoincrement())
  skill_id    Int
  name        String
  description String?
  sort_order  Int
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  skill              Skill                         @relation(fields: [skill_id], references: [id], onDelete: Cascade)
  employeeSelections EmployeeSkillTopic[]
  topicSelections    EmployeeSkillTopicSelection[]

  @@unique([skill_id, sort_order])
  @@index([skill_id])
}

model EmployeeSkill {
  id               Int         @id @default(autoincrement())
  user_id          Int
  skill_id         Int
  current_level    Int
  calculated_level Int?
  target_level     Int
  years_experience Int
  can_teach        Boolean     @default(false)
  status           SkillStatus @default(PENDING)
  created_at       DateTime    @default(now())
  updated_at       DateTime    @updatedAt

  user            User                          @relation(fields: [user_id], references: [id])
  skill           Skill                         @relation(fields: [skill_id], references: [id])
  selectedTopics  EmployeeSkillTopic[]
  topicSelections EmployeeSkillTopicSelection[]

  @@unique([user_id, skill_id])
  @@index([user_id])
  @@index([skill_id])
}

model EmployeeSkillTopic {
  id                Int @id @default(autoincrement())
  employee_skill_id Int
  skill_topic_id    Int

  employeeSkill EmployeeSkill @relation(fields: [employee_skill_id], references: [id], onDelete: Cascade)
  skillTopic    SkillTopic    @relation(fields: [skill_topic_id], references: [id], onDelete: Cascade)

  @@unique([employee_skill_id, skill_topic_id])
}

model EmployeeSkillTopicSelection {
  id                Int              @id @default(autoincrement())
  employee_skill_id Int
  skill_topic_id    Int
  proficiency_level ProficiencyLevel
  created_at        DateTime         @default(now())
  updated_at        DateTime         @updatedAt

  employeeSkill EmployeeSkill @relation(fields: [employee_skill_id], references: [id], onDelete: Cascade)
  skillTopic    SkillTopic    @relation(fields: [skill_topic_id], references: [id], onDelete: Cascade)

  @@unique([employee_skill_id, skill_topic_id])
  @@index([employee_skill_id])
}

model ApprovalRequest {
  id          Int            @id @default(autoincrement())
  user_id     Int
  field_name  String
  old_value   String?
  new_value   String
  changed_by  Int
  approved_by Int?
  status      ApprovalStatus @default(PENDING)
  created_at  DateTime       @default(now())

  user     User  @relation("ApprovalUser", fields: [user_id], references: [id])
  changer  User  @relation("ApprovalChanger", fields: [changed_by], references: [id])
  approver User? @relation("ApprovalApprover", fields: [approved_by], references: [id])
}
